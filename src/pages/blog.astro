---
import { getCollection } from 'astro:content';

import PageIntro from '_/components/PageIntro.astro';
import PostRow from '_/components/PostRow.astro';
import { EMAIL } from '_/data/site';
import BaseLayout from '_/layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const years = [...new Set(posts.map((p) => p.data.date.getUTCFullYear()))];
const byYear = (year: number) => posts.filter((p) => p.data.date.getUTCFullYear() === year);

const topics = [
  { value: 'all', label: 'All' },
  { value: 'engineering', label: 'Engineering' },
  { value: 'photography', label: 'Photography' },
];
const eyebrow = `Notes — ${posts.length} posts, ${years.length} years`;
---

<BaseLayout
  title="Writing - Kenneth Kwakye-Gyamfi"
  description="Notes by Kenneth Kwakye-Gyamfi on building software, making pictures, and the places the two overlap">
  <!-- Page Intro -->
  <PageIntro
    eyebrow={eyebrow}
    title="Writing"
    description="Notes on building software, making pictures, and the places the two overlap. Written slowly, published occasionally."
  />

  <!-- Topic filter -->
  <section class="border-border border-y">
    <div class="mx-auto max-w-5xl px-6 py-4 lg:px-8">
      <div
        class="reveal flex flex-wrap items-center gap-2"
        role="group"
        aria-label="Filter posts by topic">
        {
          topics.map((topic) => (
            <button
              type="button"
              data-topic-filter={topic.value}
              aria-pressed={topic.value === 'all' ? 'true' : 'false'}
              class="text-muted-foreground inset-ring-border hover:text-foreground aria-pressed:bg-foreground aria-pressed:text-background rounded-md px-3.5 py-1.5 text-sm inset-ring aria-pressed:font-medium aria-pressed:inset-ring-0">
              {topic.label}
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Posts by year -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl space-y-16 px-6 lg:px-8">
      {
        years.map((year) => (
          <section data-year-group class="reveal">
            <h2 class="text-caption-foreground font-mono text-sm tracking-wide uppercase">
              {year}
            </h2>
            <ul role="list" class="divide-border mt-4 divide-y">
              {byYear(year).map((post) => (
                <li data-topic={post.data.topic}>
                  <PostRow post={post} />
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </section>

  <!-- Subscribe / contact -->
  <section class="border-border border-t py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <h2
        class="reveal max-w-[24ch] text-2xl font-semibold tracking-tight text-balance sm:text-3xl">
        Want to know when something new lands?
      </h2>
      <p
        class="reveal text-muted-foreground mt-4 max-w-[55ch] text-base text-pretty [--reveal-delay:100ms]">
        No newsletter machinery yet — an email works. Say hello and I'll let you know when the next
        note is up.
      </p>
      <a
        href={`mailto:${EMAIL}?subject=Writing`}
        class="reveal decoration-border hover:decoration-foreground mt-6 inline-block text-lg font-medium underline underline-offset-4 [--reveal-delay:200ms]">
        {EMAIL}
      </a>
    </div>
  </section>

  <script>
    // Topic filtering — delegated and queried at call time (ClientRouter-safe)
    function applyTopic(topic: string) {
      document.querySelectorAll<HTMLButtonElement>('[data-topic-filter]').forEach((pill) => {
        pill.setAttribute('aria-pressed', String(pill.dataset.topicFilter === topic));
      });
      document.querySelectorAll<HTMLElement>('[data-topic]').forEach((row) => {
        row.hidden = topic !== 'all' && row.dataset.topic !== topic;
      });
      document.querySelectorAll<HTMLElement>('[data-year-group]').forEach((group) => {
        group.hidden = ![...group.querySelectorAll<HTMLElement>('[data-topic]')].some(
          (row) => !row.hidden,
        );
      });
    }

    document.addEventListener('click', (event) => {
      const pill = (event.target as Element).closest<HTMLElement>('[data-topic-filter]');
      if (pill) applyTopic(pill.dataset.topicFilter!);
    });
  </script>
</BaseLayout>
