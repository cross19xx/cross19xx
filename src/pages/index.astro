---
import { getCollection } from 'astro:content';

import { ArrowRightIcon, ExternalLinkIcon } from '@lucide/astro';

import BlurImage from '_/components/BlurImage.astro';
import ContactRow from '_/components/ContactRow.astro';
import HomeSection from '_/components/HomeSection.astro';
import PostRow from '_/components/PostRow.astro';
import ProjectRow from '_/components/ProjectRow.astro';
import { projects } from '_/data/projects';
import BaseLayout from '_/layouts/Base.astro';
import { blobUrl, MASONRY_BREAKPOINTS, padNumber } from '_/utils/misc';

import { Masonry } from 'astro-masonry';
import shuffle from 'lodash/shuffle';

const skills: { name: string; blurb: string }[] = [
  {
    name: 'Cross-platform mobile apps',
    blurb:
      'One codebase, every pocket — React Native apps that feel native on both iOS and Android.',
  },
  {
    name: 'Native mobile development',
    blurb: 'Fully native iOS and Android apps when performance and platform fidelity matter most.',
  },
  {
    name: 'Watch & tvOS development',
    blurb:
      'Native experiences for Apple Watch and Apple TV — the screens most developers never touch.',
  },
  {
    name: 'Backend development',
    blurb:
      'APIs, data models, and infrastructure that quietly keep everything above them running. Python is my jam.',
  },
];

const featuredProjects = projects.filter((project) => project.featured);

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const photos = await getCollection('photos');
const featuredPhotos = shuffle(photos.filter((photo) => photo.data.featured));
---

<BaseLayout
  title="Kenneth Kwakye-Gyamfi - Software Engineer + Photographer"
  description="Kenneth Kwakye-Gyamfi is a senior mobile & web full stack engineer, husband, father, photographer, and a proud Ghanaian.">
  <!-- Opt this page out of the global reveal observer; Motion drives reveals below. -->
  <div data-motion-reveals hidden></div>

  <!-- Hero section -->
  <section class="pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <p class="reveal text-caption-foreground font-mono text-sm tracking-wide uppercase">
        Accra, Ghana — 5.6037° N, 0.1870° W
      </p>
      <h1
        class="reveal font-display mt-6 max-w-[24ch] text-4xl font-medium tracking-tight text-balance [--reveal-delay:100ms] sm:text-5xl md:text-6xl">
        Mobile Engineer with a camera never far from reach.
      </h1>
      <p
        class="reveal text-muted-foreground mt-6 max-w-[55ch] text-lg text-pretty [--reveal-delay:200ms]">
        I'm Kenneth Kwakye-Gyamfi, a senior mobile & web full stack engineer, husband, father,
        photographer, and a proud Ghanaian.
      </p>

      <div class="reveal mt-10 flex flex-wrap items-center gap-6 [--reveal-delay:300ms]">
        <a
          href={blobUrl('Kenneth_Kwakye-Gyamfi_Resume.pdf')}
          target="_blank"
          class="bg-foreground/90 text-background hover:bg-foreground rounded-md px-5 py-2.5 text-sm font-medium transition-transform active:scale-98">
          Résumé (PDF) ↗
        </a>
        <a
          href="/about"
          class="border-border text-foreground hover:border-foreground/40 rounded-md border px-5 py-2.5 text-sm font-medium transition-transform active:scale-98">
          About me
        </a>
        <a
          href="https://www.github.com/cross19xx"
          class="text-muted-foreground hover:text-foreground text-sm font-medium">
          GitHub ↗
        </a>
      </div>

      <p class="reveal text-muted-foreground mt-8 font-mono text-sm [--reveal-delay:400ms]">
        9+ years shipping mobile — most recently Senior Mobile/ Full-Stack Engineer at Wellthy
        &middot;
        <a
          href="/about#experience"
          class="text-foreground decoration-border hover:text-foreground/90 hover:decoration-foreground/90 underline underline-offset-4"
          >full history</a
        >
      </p>
    </div>
  </section>

  <!-- Work: what I do + projects (merged) -->
  <HomeSection
    id="work"
    title="What I do"
    eyebrow="01 / Work"
    description="Most of my work lives on a screen in someone's pocket. I build mobile apps end to end — iOS, Android, Watch, tvOS — and handle the backend and web layers that sit behind them."
    link={{ text: 'All Projects', href: '/projects' }}>
    <ul role="list" class="mt-12 grid grid-cols-1 gap-x-12 gap-y-10 sm:grid-cols-2">
      {
        skills.map(({ name, blurb }, i) => (
          <li class={`reveal flex gap-5 ${i % 2 === 1 ? 'sm:[--reveal-delay:100ms]' : ''}`}>
            <span class="text-caption-foreground font-mono text-sm">{padNumber(i + 1)}</span>
            <div>
              <h3 class="text-base font-medium">{name}</h3>
              <p class="text-muted-foreground mt-1.5 text-base text-pretty">{blurb}</p>
            </div>
          </li>
        ))
      }
    </ul>

    <div
      class="reveal border-border mt-16 flex items-baseline justify-between gap-6 border-t pt-10">
      <h3 class="text-xl font-semibold tracking-tight">Selected projects</h3>
      <p class="text-caption-foreground font-mono text-sm tracking-wide uppercase">Building next</p>
    </div>
    <p class="reveal text-muted-foreground mt-4 max-w-[55ch] text-base text-pretty">
      A bench of ideas in various states of done — some shipping, some still sketches in a notebook.
    </p>
    <ul role="list" class="divide-border/50 mt-8 divide-y">
      {featuredProjects.map((project, i) => <ProjectRow project={project} index={i} />)}
    </ul>
  </HomeSection>

  <!-- Blog/Writing -->
  <HomeSection
    id="writing"
    title="Writing"
    eyebrow="02 / Notes"
    description="Occasional notes on building software, making pictures, and the places the two overlap."
    link={{ text: 'All Posts', href: '/blog' }}>
    <ul role="list" class="divide-border/50 mt-8 divide-y">
      {
        posts.map((post) => (
          <li class="reveal">
            <PostRow post={post} />
          </li>
        ))
      }
    </ul>
  </HomeSection>

  <!-- Photography -->
  <HomeSection
    id="photography"
    title="Photography"
    eyebrow="03 / Field Notes"
    description="Code pays the bills; photography keeps the eye sharp — the same sense of light, framing, and timing I bring to the interfaces I build. A rolling selection from Accra and wherever the road goes.">
    <Masonry breakpointCols={MASONRY_BREAKPOINTS} class="mt-12 gap-4">
      {
        featuredPhotos.map(({ data: photo }) => (
          <figure class="reveal mb-4 break-inside-avoid sm:mb-5">
            <a
              href="/photography"
              class="group block overflow-hidden rounded-sm outline-1 -outline-offset-1 outline-white/10">
              <BlurImage
                src={photo.url}
                width={photo.width}
                height={photo.height}
                hash={photo.blurhash}
                alt={photo.description}
              />
            </a>
            <figcaption class="text-caption-foreground mt-2 flex justify-between font-mono text-xs">
              <span>{photo.label}</span>
              <span>{photo.name}</span>
            </figcaption>
          </figure>
        ))
      }
    </Masonry>

    <div class="reveal mt-10 flex flex-wrap items-center gap-6">
      <a
        href="/photography"
        class="bg-primary text-primary-foreground/90 hover:text-primary-foreground inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-medium transition-transform active:scale-98">
        Browse full archive <ArrowRightIcon class="size-3" />
      </a>
      <a
        href="https://www.instagram.com/kenneth_kwakyegyamfi"
        class="text-foreground/90 hover:text-foreground inline-flex items-center gap-2 text-sm font-medium"
        target="_blank">
        Instagram <ExternalLinkIcon class="size-3" />
      </a>
    </div>
  </HomeSection>

  <!-- About -->
  <section id="about" class="border-border scroll-mt-24 border-t py-20 sm:py-28">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-x-16 gap-y-10 md:grid-cols-[1fr_2fr]">
        <div class="reveal flex items-baseline justify-between gap-6 md:block">
          <h2 class="text-2xl font-semibold tracking-tight">About</h2>
          <p class="text-caption-foreground font-mono text-sm tracking-wide uppercase md:mt-2">
            04 / Person
          </p>
        </div>
        <div class="reveal text-muted-foreground space-y-5 text-base md:[--reveal-delay:100ms]">
          <p class="max-w-[60ch] text-pretty">
            Nine years in, my work spans the full arc of a product — wireframing the first screens,
            building the apps people actually hold, and running the backends behind them. Mostly
            React Native with native Swift and Kotlin underneath, across regulated, high-consequence
            domains: healthcare, banking, emergency response.
          </p>
          <p class="max-w-[60ch] text-pretty">
            The camera came first, though — and the eye it trained for light, framing, and timing is
            the same one I bring to an interface.
          </p>
          <a
            href="/about"
            class="reveal text-muted-foreground hover:text-foreground mt-6 inline-flex items-center gap-2 text-sm font-medium">
            More about me <ArrowRightIcon class="size-3" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <ContactRow
    message="Have a project in mind — or a print you'd like on your wall?"
    eyebrow="05 / Contact"
  />
</BaseLayout>

<!-- Scroll-choreography prototype: homepage reveal overrides -->
<style is:global>
  /* The homepage drives reveals with Motion (see script), so neutralise the
     global IntersectionObserver reveal here: Motion owns the initial + final
     state and the two systems never fight over opacity/transform. Scoped to
     this page via :has() on the marker, and gated by reduced-motion to match
     the rest of the site (reduced-motion users get static, visible content). */
  @media (prefers-reduced-motion: no-preference) {
    html:has([data-motion-reveals]) .reveal {
      opacity: 0;
      translate: none;
      transition: none;
    }
    /* Text/UI rise + scale in; photos fade only (parallax owns their transform). */
    html:has([data-motion-reveals]) .reveal:not(figure) {
      transform: translateY(16px) scale(0.985);
    }
  }
</style>

<script>
  import { animate, inView, scroll } from 'motion';

  const initScrollChoreography = () => {
    // Only the homepage opts in (the marker is rendered on this page only), and
    // never under reduced-motion — matches the site's existing convention.
    if (!document.querySelector('[data-motion-reveals]')) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // 1) Spring reveals, staggered per section as each scrolls into view.
    inView(
      'section',
      (section) => {
        const reveals = Array.from(section.querySelectorAll<HTMLElement>('.reveal'));
        reveals.forEach((el, i) => {
          const delay = i * 0.06;
          if (el.matches('figure')) {
            // Photos fade only — the parallax below owns their transform.
            animate(el, { opacity: [0, 1] }, { duration: 0.7, delay, ease: [0.22, 1, 0.36, 1] });
          } else {
            animate(
              el,
              { opacity: [0, 1], y: [16, 0], scale: [0.985, 1] },
              { type: 'spring', stiffness: 130, damping: 18, delay },
            );
          }
        });
      },
      { amount: 0.15 },
    );

    // 2) Subtle scroll-linked parallax on the photography grid.
    const gallery = document.querySelector('#photography');
    if (gallery) {
      const figures = Array.from(gallery.querySelectorAll<HTMLElement>('figure'));
      scroll(
        (progress: number) => {
          for (let i = 0; i < figures.length; i++) {
            // Centred at the section midpoint; columns drift at slightly
            // different rates so the grid reads as layered, not a single sheet.
            const range = 14 + (i % 3) * 6;
            const y = (0.5 - progress) * range;
            figures[i].style.transform = `translateY(${y.toFixed(2)}px)`;
          }
        },
        { target: gallery, offset: ['start end', 'end start'] },
      );
    }
  };

  document.addEventListener('astro:page-load', initScrollChoreography);
</script>
