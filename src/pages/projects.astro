---
import PageIntro from '_/components/PageIntro.astro';
import ProjectRow from '_/components/ProjectRow.astro';
import { projects } from '_/data/projects';
import { EMAIL } from '_/data/site';
import BaseLayout from '_/layouts/Base.astro';

const eyebrow = `Bench — ${projects.length} projects, 3 states of done`;
---

<BaseLayout
  title="Projects — Kenneth Kwakye-Gyamfi"
  description="Projects by Kenneth Kwakye-Gyamfi — apps, tools, and ideas in various states of done.">
  <PageIntro
    eyebrow={eyebrow}
    description="Projects by Kenneth Kwakye-Gyamfi — apps, tools, and ideas in various states of done."
    title="Projects"
  />

  <!-- Project list -->
  <div class="border-border border-t py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <ul role="list" class="divide-border divide-y">
        {projects.map((project, i) => <ProjectRow project={project} index={i} class="py-10" />)}
      </ul>
    </div>
  </div>

  <!-- Collaborate -->
  <section class="border-border border-t py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <h2
        class="reveal max-w-[24ch] text-2xl font-semibold tracking-tight text-balance sm:text-3xl">
        See something worth building together?
      </h2>
      <a
        href={`mailto:${EMAIL}?subject=Projects`}
        class="reveal decoration-border hover:decoration-foreground mt-6 inline-block text-lg font-medium underline underline-offset-4 [--reveal-delay:100ms]">
        {EMAIL}
      </a>
    </div>
  </section>
</BaseLayout>
