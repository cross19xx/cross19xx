---
import { Image } from 'astro:assets';
import { getCollection, type InferEntrySchema } from 'astro:content';

import Lightbox from '_/components/Lightbox.astro';
import PageIntro from '_/components/PageIntro.astro';
import { EMAIL } from '_/data/site';
import BaseLayout from '_/layouts/Base.astro';
import { MASONRY_BREAKPOINTS } from '_/utils/misc';

import { Masonry } from 'astro-masonry';

type MappedAlbum = InferEntrySchema<'albums'> & {
  photos: InferEntrySchema<'photos'>[];
  id: string;
  totalPhotosCount: number;
  showViewMore: boolean;
};

const albums = await getCollection('albums');
const photos = await getCollection('photos');

const tags = Array.from(new Set(photos.flatMap((photo) => photo.data.tags)));
tags.unshift('All');

const mappedAlbums: MappedAlbum[] = albums.map((album) => {
  const albumPhotos = photos
    .filter((photo) => photo.data.album?.id === album.id)
    .map((photo) => photo.data);

  const showViewMore = albumPhotos.length > 5;

  return {
    ...album.data,
    id: album.id,
    totalPhotosCount: albumPhotos.length,
    photos: albumPhotos.slice(0, 5),
    showViewMore,
  };
});

const pageTitle = 'Photography — Kenneth Kwakye-Gyamfi';
const pageDescription =
  'Photography archive of Kenneth Kwakye-Gyamfi — albums from Accra, the Ghanaian coast, and beyond.';
const eyebrow = `Archive — ${photos.length} photos, ${albums.length} albums`;

const pillClass =
  'rounded-full px-3.5 py-1.5 text-sm text-muted-foreground inset-ring inset-ring-border/50 hover:text-foreground aria-pressed:bg-foreground aria-pressed:font-medium aria-pressed:text-background aria-pressed:inset-ring-0';
const chipClass =
  'tag-chip text-muted-foreground inset-ring inset-ring-border/50 hover:text-foreground';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <PageIntro
    eyebrow={eyebrow}
    title="Photographs"
    description="Frames from all over the world, shot on my Sony A7 IV, edited lightly, captioned honestly. Filter by what you're in the mood for."
  />

  <!-- Filter Bar -->
  <div class="border-border/50 border-y">
    <div class="mx-auto max-w-5xl px-6 py-4 lg:px-8">
      <div
        class="reveal flex flex-wrap items-center gap-2"
        role="group"
        aria-label="Filter photos by tag">
        {
          tags.map((tag) => (
            <button
              type="button"
              data-filter={tag}
              aria-pressed={tag === 'All' ? 'true' : 'false'}
              class={pillClass}>
              {tag}
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Albums -->
  <div class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl space-y-20 px-6 lg:px-8">
      {
        mappedAlbums.map((album) => (
          <section data-album class="reveal">
            <div class="flex items-baseline justify-between gap-6">
              <h2 class="text-2xl font-semibold tracking-tight">{album.title}</h2>
              <p class="text-caption-foreground font-mono text-sm tracking-wide uppercase">
                {album.label}
              </p>
            </div>
            <p class="text-muted-foreground mt-3 max-w-[55ch] text-base text-pretty">
              {album.description}
            </p>
            <Masonry breakpointCols={MASONRY_BREAKPOINTS} class="mt-8 gap-4">
              {album.photos.map((photo) => (
                <figure data-tags={photo.tags.join(',')} class="mb-4 break-inside-avoid sm:mb-5">
                  <button
                    type="button"
                    data-lightbox-open
                    data-src={photo.url}
                    data-alt={photo.alt}
                    data-title={photo.title}
                    data-exif={photo.exif}
                    data-file={photo.file}
                    class="group outline-border block w-full cursor-zoom-in overflow-hidden rounded-sm outline-1 -outline-offset-1">
                    <Image
                      src={photo.url}
                      alt={photo.alt}
                      inferSize
                      loading="lazy"
                      class={`${photo.aspect} w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105`}
                    />
                  </button>
                  <figcaption class="mt-2.5 space-y-1.5">
                    <div class="flex justify-between font-mono text-xs">
                      <span class="text-foreground">{photo.title}</span>
                      <span class="text-muted-foreground">{photo.file}</span>
                    </div>
                    <p class="text-caption-foreground font-mono text-xs">{photo.exif}</p>
                    <div class="flex flex-wrap gap-1.5">
                      {photo.tags.map((tag) => (
                        <button type="button" data-tag={tag} class={chipClass}>
                          {tag}
                        </button>
                      ))}
                    </div>
                  </figcaption>
                </figure>
              ))}
            </Masonry>

            <div class="pt-12 text-center">
              <a
                href={`/albums/${album.id}`}
                class="decoration-border hover:decoration-foreground font-medium underline underline-offset-4">
                View all {album.totalPhotosCount} photos
              </a>
            </div>
          </section>
        ))
      }

      <!-- Empty state -->
      <p data-empty hidden class="text-caption-foreground font-mono text-sm">
        No frames match that tag yet — try another.
      </p>
    </div>
  </div>

  <!-- Prints -->
  <section class="border-border/50 border-t py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <h2
        class="reveal max-w-[24ch] text-2xl font-semibold tracking-tight text-balance sm:text-3xl">
        Most frames are available as prints.
      </h2>
      <a
        href={`mailto:${EMAIL}?subject=Print%20enquiry`}
        class="reveal decoration-border hover:decoration-foreground mt-6 inline-block text-lg font-medium underline underline-offset-4 [--reveal-delay:100ms]">
        {EMAIL}
      </a>
    </div>
  </section>

  <Lightbox />
</BaseLayout>
