---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';

import Lightbox from '_/components/Lightbox.astro';
import PageIntro from '_/components/PageIntro.astro';
import BaseLayout from '_/layouts/Base.astro';
import { constructPageTitle, MASONRY_BREAKPOINTS } from '_/utils/misc';

import { Masonry } from 'astro-masonry';

interface Props {
  album: CollectionEntry<'albums'>;
  photos: CollectionEntry<'photos'>[];
}

export async function getStaticPaths() {
  const paths = [];

  const albums = await getCollection('albums');
  const photos = await getCollection('photos');

  for (const album of albums) {
    const albumPhotos = photos.filter((photo) => photo.data.album?.id === album.id);

    paths.push({
      params: { id: album.id },
      props: {
        album,
        photos: albumPhotos,
      },
    });
  }

  return paths;
}

const { album, photos } = Astro.props;
const pageTitle = constructPageTitle(album.data.title);
const pageDescription = `${album.data.title} - ${album.data.description}`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <PageIntro
    eyebrow={album.data.label}
    title={album.data.title}
    description={album.data.description}
  />

  <section class="border-border border-y">
    <div class="mx-auto max-w-5xl px-6 py-4 lg:px-8">
      <Masonry breakpointCols={MASONRY_BREAKPOINTS} class="gap-4">
        {
          photos.map(({ data: photo }) => (
            <figure data-tags={photo.tags.join(',')} class="mb-4 break-inside-avoid sm:mb-5">
              <button
                type="button"
                data-lightbox-open
                data-src={photo.url}
                data-alt={photo.alt}
                data-title={photo.title}
                data-exif={photo.exif}
                data-file={photo.file}
                class="group outline-border block w-full cursor-zoom-in overflow-hidden rounded-sm outline-1 -outline-offset-1">
                <Image
                  src={photo.url}
                  inferSize
                  alt={photo.alt}
                  loading="lazy"
                  class={`${photo.aspect} w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105`}
                />
              </button>

              <figcaption class="mt-2.5 space-y-1.5">
                <div class="flex justify-between font-mono text-xs">
                  <span class="text-foreground">{photo.title}</span>
                  <span class="text-muted-foreground">{photo.file}</span>
                </div>
                <p class="text-caption-foreground font-mono text-xs">{photo.exif}</p>
                <div class="flex flex-wrap gap-1.5">
                  {photo.tags.map((tag) => (
                    <p class="tag-chip text-muted-foreground inset-ring-border/50 hover:text-foreground inset-ring">
                      {tag}
                    </p>
                  ))}
                </div>
              </figcaption>
            </figure>
          ))
        }
      </Masonry>
    </div>
  </section>

  <Lightbox />
</BaseLayout>
