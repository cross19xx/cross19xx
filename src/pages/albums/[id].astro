---
import { type CollectionEntry, getCollection } from 'astro:content';

import { ArrowLeftIcon } from '@lucide/astro';

import BlurImage from '_/components/BlurImage.astro';
import Lightbox from '_/components/Lightbox.astro';
import PageIntro from '_/components/PageIntro.astro';
import BaseLayout from '_/layouts/Base.astro';
import { constructPageTitle, MASONRY_BREAKPOINTS } from '_/utils/misc';

import { Masonry } from 'astro-masonry';

interface Props {
  album: CollectionEntry<'albums'>;
  photos: CollectionEntry<'photos'>[];
}

export async function getStaticPaths() {
  const paths = [];

  const albums = await getCollection('albums');
  const photos = await getCollection('photos');

  for (const album of albums) {
    const albumPhotos = photos.filter((photo) => photo.data.album?.id === album.id);

    paths.push({
      params: { id: album.id },
      props: {
        album,
        photos: albumPhotos,
      },
    });
  }

  return paths;
}

const { album, photos } = Astro.props;
const pageTitle = constructPageTitle(album.data.title);
const pageDescription = `${album.data.title} - ${album.data.description}`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <PageIntro
    eyebrow={album.data.label}
    title={album.data.title}
    description={album.data.description}>
    <p slot="page-link" class="mb-4">
      <a
        href="/photography"
        class="reveal text-foreground/80 hover:text-foreground inline-flex items-center gap-2 font-mono text-sm"
        ><ArrowLeftIcon class="size-3" /> All Albums</a
      >
    </p>
  </PageIntro>
  <section class="border-border border-y">
    <div class="mx-auto max-w-5xl px-6 py-4 lg:px-8">
      <Masonry breakpointCols={MASONRY_BREAKPOINTS} class="gap-4">
        {
          photos.map(({ data: photo }) => {
            const exif = [
              photo.makeAndModel,
              photo.lens,
              photo.aperture,
              photo.shutterSpeed,
              photo.iso,
            ]
              .filter(Boolean)
              .join(' · ');
            return (
              <figure data-tags={photo.tags.join(',')} class="mb-4 break-inside-avoid sm:mb-5">
                <button
                  type="button"
                  data-lightbox-open
                  data-src={photo.url}
                  data-alt={photo.description}
                  data-title={photo.label}
                  data-exif={exif}
                  data-file={photo.name}
                  class="group outline-border block w-full cursor-zoom-in overflow-hidden rounded-sm outline-1 -outline-offset-1">
                  <BlurImage
                    src={photo.url}
                    alt={photo.label}
                    hash={photo.blurhash}
                    width={photo.width}
                    height={photo.height}
                  />
                </button>
              </figure>
            );
          })
        }
      </Masonry>
    </div>
  </section>

  <Lightbox />
</BaseLayout>
