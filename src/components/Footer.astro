---
import { SOCIAL_MEDIA } from '_/data/site';
---

<footer class="border-border border-t py-10">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-6 px-6 sm:flex-row sm:items-center sm:justify-between lg:px-8">
    <p class="text-caption-foreground text-sm">© 2026 Kenneth Kwakye-Gyamfi · Accra, Ghana</p>
    <ul role="list" class="text-muted-foreground flex items-center gap-5 text-sm">
      {
        SOCIAL_MEDIA.map((social) => (
          <li>
            <a
              href={social.href}
              class="hover:text-foreground"
              target="_blank"
              rel="noopener noreferrer">
              {social.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
