---
import { Font } from 'astro:assets';

import { OG_HEIGHT, OG_WIDTH, ogImagePath } from '_/lib/og/paths';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { description, title, image } = Astro.props;

// An explicit `image` wins; otherwise reference the card generated for this
// route (see src/pages/og/[...slug].png.ts)
const ogImage = new URL(image ?? ogImagePath(Astro.url.pathname), Astro.site);
const ogImageIsGenerated = !image;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />

<Font cssVariable="--font-geist" preload />
<Font cssVariable="--font-geist-mono" preload />
<Font cssVariable="--font-lora" preload />

<link rel="canonical" href={Astro.url} />

<link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="sitemap" href="/sitemap-index.xml" />

<meta property="og:site_name" content="Kenneth Kwakye-Gyamfi" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:image" content={ogImage.href} />
{
  ogImageIsGenerated && (
    <Fragment>
      <meta property="og:image:width" content={String(OG_WIDTH)} />
      <meta property="og:image:height" content={String(OG_HEIGHT)} />
    </Fragment>
  )
}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImage.href} />
