<!-- Lightbox. Uses native Tailwind color classes -->
<dialog
  data-lightbox
  class="m-auto max-w-4xl bg-transparent p-4 outline-none backdrop:bg-neutral-950/85 backdrop:backdrop-blur-sm">
  <figure class="cursor-zoom-out">
    <img data-lightbox-img class="max-h-[80vh] w-auto rounded-sm" alt="" />
    <figcaption
      class="mt-3 flex flex-wrap justify-between gap-4 font-mono text-xs text-neutral-400">
      <span data-lightbox-title class="text-neutral-200"></span>
      <span data-lightbox-exif></span>
    </figcaption>
  </figure>
</dialog>

<script>
  // Tag filtering + lightbox — fully delegated and querying at call time,
  // so both survive ClientRouter page swaps without re-initialization.
  function applyFilter(tag: string) {
    document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((pill) => {
      pill.setAttribute('aria-pressed', String(pill.dataset.filter === tag));
    });
    document.querySelectorAll<HTMLElement>('[data-tags]').forEach((photo) => {
      photo.hidden = tag !== 'All' && !photo.dataset.tags!.split(',').includes(tag);
    });
    let anyVisible = false;
    document.querySelectorAll<HTMLElement>('[data-album]').forEach((album) => {
      const visible = [...album.querySelectorAll<HTMLElement>('[data-tags]')].some(
        (p) => !p.hidden,
      );
      album.hidden = !visible;
      if (visible) anyVisible = true;
    });
    const emptyState = document.querySelector<HTMLElement>('[data-empty]');
    if (emptyState) emptyState.hidden = anyVisible;
  }

  document.addEventListener('click', (event) => {
    const target = event.target as Element;

    const filterTrigger = target.closest<HTMLElement>('[data-filter], [data-tag]');
    if (filterTrigger) {
      applyFilter(filterTrigger.dataset.filter ?? filterTrigger.dataset.tag!);
      return;
    }

    const lightbox = document.querySelector<HTMLDialogElement>('[data-lightbox]');
    if (!lightbox) return;

    const opener = target.closest<HTMLElement>('[data-lightbox-open]');
    if (opener) {
      const img = lightbox.querySelector<HTMLImageElement>('[data-lightbox-img]')!;
      img.src = opener.dataset.src!;
      img.alt = opener.dataset.alt ?? '';
      lightbox.querySelector('[data-lightbox-title]')!.textContent = opener.dataset.title!;
      lightbox.querySelector('[data-lightbox-exif]')!.textContent =
        `${opener.dataset.exif} · ${opener.dataset.file}`;
      lightbox.showModal();
      return;
    }

    // Any click while open (image, caption, or backdrop) closes it; Esc is native
    if (lightbox.open && target.closest('[data-lightbox]')) {
      lightbox.close();
    }
  });
</script>
